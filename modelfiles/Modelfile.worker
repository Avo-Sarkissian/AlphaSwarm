# AlphaSwarm Worker Agent Model
# Register with: ollama create alphaswarm-worker -f modelfiles/Modelfile.worker
# Base: qwen3:8b — qwen3moe arch supports parallel requests in ollama 0.21.2
# (qwen3.5:9b was forced to Parallel=1 by the qwen35 arch limitation, see
# 41.4-MODEL-DECISION-LOG.md and ollama issues #14510, #14621, #14879).
FROM qwen3:8b
PARAMETER num_ctx 4096
PARAMETER temperature 0.7
PARAMETER num_gpu 999
# Decision JSON is ~100-150 tokens; 400 caps pathological repetition loops
# (the 14-20 min/call tail observed in the 41.3 smoke) at zero quality cost.
# Re-register after editing: ollama create alphaswarm-worker -f modelfiles/Modelfile.worker
PARAMETER num_predict 400
