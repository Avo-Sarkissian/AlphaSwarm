# AlphaSwarm Configuration
# All vars prefixed with ALPHASWARM_
# Nested settings use __ delimiter

ALPHASWARM_DEBUG=false
ALPHASWARM_LOG_LEVEL=INFO

# ── Local Ollama (DEFAULT inference backend) ──────────────────────────────────
# These vars configure the on-device Ollama server used when no cloud provider
# is configured. For cloud / API inference, use the Settings UI in the web app
# or edit .secrets/inference.json directly — that file is gitignored and is the
# single source of truth for provider selection, model, API key, rate limits,
# and spend cap. No environment variables control cloud provider selection.
ALPHASWARM_OLLAMA__ORCHESTRATOR_MODEL=qwen3.6:27b-nvfp4
ALPHASWARM_OLLAMA__WORKER_MODEL=qwen3.6:35b-a3b-nvfp4
ALPHASWARM_OLLAMA__NUM_PARALLEL=16
ALPHASWARM_OLLAMA__MAX_LOADED_MODELS=2
ALPHASWARM_OLLAMA__BASE_URL=http://localhost:11434
ALPHASWARM_OLLAMA__ORCHESTRATOR_MODEL_ALIAS=alphaswarm-orchestrator
ALPHASWARM_OLLAMA__WORKER_MODEL_ALIAS=alphaswarm-worker

# Neo4j
ALPHASWARM_NEO4J__URI=bolt://localhost:7687
ALPHASWARM_NEO4J__USERNAME=neo4j
ALPHASWARM_NEO4J__PASSWORD=alphaswarm
ALPHASWARM_NEO4J__DATABASE=neo4j

# Resource Governor
ALPHASWARM_GOVERNOR__BASELINE_PARALLEL=8
ALPHASWARM_GOVERNOR__MAX_PARALLEL=16
ALPHASWARM_GOVERNOR__MEMORY_THROTTLE_PERCENT=80.0
ALPHASWARM_GOVERNOR__MEMORY_PAUSE_PERCENT=90.0
ALPHASWARM_GOVERNOR__CHECK_INTERVAL_SECONDS=2.0
