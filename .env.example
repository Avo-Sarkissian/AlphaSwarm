# AlphaSwarm Configuration
# All vars prefixed with ALPHASWARM_
# Nested settings use __ delimiter

ALPHASWARM_DEBUG=false
ALPHASWARM_LOG_LEVEL=INFO

# Ollama
ALPHASWARM_OLLAMA__ORCHESTRATOR_MODEL=qwen3:32b
ALPHASWARM_OLLAMA__WORKER_MODEL=qwen3.5:4b
ALPHASWARM_OLLAMA__NUM_PARALLEL=16
ALPHASWARM_OLLAMA__MAX_LOADED_MODELS=2
ALPHASWARM_OLLAMA__BASE_URL=http://localhost:11434

# Neo4j
ALPHASWARM_NEO4J__URI=bolt://localhost:7687
ALPHASWARM_NEO4J__USERNAME=neo4j
ALPHASWARM_NEO4J__PASSWORD=alphaswarm
ALPHASWARM_NEO4J__DATABASE=neo4j

# Resource Governor
ALPHASWARM_GOVERNOR__BASELINE_PARALLEL=8
ALPHASWARM_GOVERNOR__MAX_PARALLEL=16
ALPHASWARM_GOVERNOR__MEMORY_THROTTLE_PERCENT=80.0
ALPHASWARM_GOVERNOR__MEMORY_PAUSE_PERCENT=90.0
ALPHASWARM_GOVERNOR__CHECK_INTERVAL_SECONDS=2.0
